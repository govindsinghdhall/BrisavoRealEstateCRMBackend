# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_NAME=RealEstateCRM

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real_estate_crm?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password Reset
PASSWORD_RESET_EXPIRES_IN=1h

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@realestatecrm.com

# SMS
SMS_API_KEY=
SMS_API_URL=

# WhatsApp
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Public Website API (optional — protects POST /public/inquiries)
WEBSITE_API_KEY=your-website-api-key
